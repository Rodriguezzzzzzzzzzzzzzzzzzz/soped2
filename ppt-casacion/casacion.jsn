  });

  const criticas = [
    { t: "Ausencia de prueba directa del acuerdo simulatorio", d: "La sentencia se apoya exclusivamente en indicios. No obra en autos el contracarta ni otro medio que acredite el pactum simulationis entre codemandados." },
    { t: "Presunción de conocimiento no probada directamente", d: "Se infiere que Roca Rojas conocía las pretensiones de Koch Müller, pero no se acredita que haya sido notificado formalmente del proceso de Ineficacia." },
    { t: "Posible afectación de la seguridad jurídica registral", d: "Debilitar el Art. 2014 CC en base a indicios genera incertidumbre en el tráfico jurídico inmobiliario y puede desalentar inversiones." },
    { t: "Motivación escueta de la Corte Suprema", d: "Los considerandos SEXTO y SÉTIMO son excesivamente breves para la complejidad jurídica del caso; no desarrollan suficientemente la doctrina sobre la mala fe." },
  ];
  criticas.forEach((p, i) => {
    s.addText(p.t, {
