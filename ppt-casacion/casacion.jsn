  });

  const preguntas = [
    { n: "?", t: "¿Fue suficiente el estándar probatorio?", d: "¿Es razonable declarar nulo un acto jurídico inscrito basándose solo en indicios, sin acreditar directamente el pactum simulationis?" },
    { n: "?", t: "Buena fe registral vs. realidad sustantiva", d: "¿Cómo equilibrar la seguridad jurídica del tráfico inmobiliario con la protección de quienes ven vulnerados sus derechos por actos simulados?" },
    { n: "?", t: "¿Conocimiento equivale a mala fe?", d: "¿Es suficiente que Roca Rojas conociera el proceso judicial de Koch Müller para presumir su mala fe? ¿O debió probarse su participación activa en el fraude?" },
    { n: "?", t: "Rol de la inscripción registral", d: "Si el principio de publicidad registral (Art. 2012 CC) crea presunción de conocimiento, ¿podría haberse usado en sentido inverso para proteger a Koch Müller desde la anotación del proceso?" },
    { n: "?", t: "Acción de ineficacia vs. nulidad por simulación", d: "¿Fue la acción correcta? ¿Debió Koch Müller acumular la acción pauliana (Art. 195 CC) o era suficiente la nulidad por simulación del Art. 190 CC?" },
    { n: "?", t: "Sociedad de gananciales no liquidada", d: "¿Cuál es el régimen jurídico del bien desde el divorcio (1996) hasta la transferencia (2012)? ¿Poseía realmente Koch Müller un derecho inscribible sobre el bien?" },
  ];

  preguntas.forEach((p, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const xx = 0.5 + col * 6.35;
    const yy = 1.3 + row * 2.0;

    s.addShape(pres.shapes.RECTANGLE, {
      x: xx, y: yy, w: 6.1, h: 1.8,
      fill: { color: C.white },
      shadow: makeShadow(),
      line: { color: C.lgray, width: 0.5 }
    });
    s.addShape(pres.shapes.RECTANGLE, {
      x: xx, y: yy, w: 0.55, h: 1.8,
      fill: { color: C.navy }
    });
    s.addText("?", {
      x: xx, y: yy, w: 0.55, h: 1.8,
      fontSize: 28, color: C.gold, bold: true, fontFace: "Georgia",
      align: "center", valign: "middle", margin: 0
    });
    s.addText(p.t, {
      x: xx + 0.65, y: yy + 0.15, w: 5.3, h: 0.45,
      fontSize: 11, color: C.navy, bold: true, margin: 0
    });
    s.addText(p.d, {
      x: xx + 0.65, y: yy + 0.62, w: 5.3, h: 1.0,
      fontSize: 10, color: C.slate, margin: 0
    });
  });

  s.addNotes("DEBATE — Estas preguntas invitan a reflexión crítica. La pregunta 6 es la más compleja: si la sociedad de gananciales no fue liquidada, Koch Müller era técnicamente copropietaria, lo que refuerza su legitimidad. Sin embargo, la falta de inscripción de ese derecho es el talón de Aquiles de su posición.");
}

