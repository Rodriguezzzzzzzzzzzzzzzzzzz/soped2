    x: 0.7, y: 1.3, w: 5.6, h: 0.55,
    fontSize: 10, color: C.gold, bold: true, charSpacing: 1,
    align: "center", valign: "middle", margin: 0
  });

  const pasos = [
    { n: "1", t: "Validez de la prueba indiciaria", d: "Arts. 275-277 CPC: no existe impedimento para que una sentencia se base en indicios. La ley expresamente lo permite." },
    { n: "2", t: "Suficiencia de los indicios", d: "Los seis indicios identificados por la Sala Superior son concordantes, convergentes y suficientes para acreditar la simulación." },
    { n: "3", t: "Discordancia voluntad-declaración", d: "Los elementos prueban que las partes NUNCA quisieron transferir la propiedad, sino impedir que Koch Müller ejerciera sus derechos." },
    { n: "4", t: "Inaplicabilidad del Art. 2014 CC", d: "La buena fe registral protege solo a quien actuó sin conocer la verdad. Roca Rojas conocía las pretensiones de la demandante." },
    { n: "5", t: "Consecuencia: simulación absoluta", d: "El acuerdo simulatorio tácito entre vendedor y comprador para sustraer el bien configura el supuesto del Art. 190 CC." },
  ];

  pasos.forEach((p, i) => {
    s.addShape(pres.shapes.OVAL, {
      x: 0.65, y: 2.05 + i * 0.97, w: 0.35, h: 0.35,
      fill: { color: C.gold }
    });
    s.addText(p.n, {
      x: 0.65, y: 2.05 + i * 0.97, w: 0.35, h: 0.35,
      fontSize: 9, color: C.navy, bold: true, align: "center", valign: "middle", margin: 0
    });
    s.addText(p.t, {
      x: 1.1, y: 2.02 + i * 0.97, w: 5.2, h: 0.3,
      fontSize: 10.5, color: C.navy, bold: true, margin: 0
    });
    s.addText(p.d, {
      x: 1.1, y: 2.34 + i * 0.97, w: 5.2, h: 0.55,
      fontSize: 9.5, color: C.slate, margin: 0
    });
    if (i < 4) {
      s.addShape(pres.shapes.LINE, {
        x: 0.8, y: 2.97 + i * 0.97, w: 0, h: 0.3,
        line: { color: C.lgray, width: 0 }
      });
    }
  });

  // Right: Estructura motivación
  s.addShape(pres.shapes.RECTANGLE, {
    x: 6.8, y: 1.3, w: 5.9, h: 5.6,
    fill: { color: C.white },
    shadow: makeShadow(),
    line: { color: C.lgray, width: 0.5 }
  });
  s.addShape(pres.shapes.RECTANGLE, {
    x: 6.8, y: 1.3, w: 5.9, h: 0.55,
    fill: { color: C.gold }
  });
  s.addText("ESTRUCTURA DE MOTIVACIÓN", {
    x: 7.0, y: 1.3, w: 5.5, h: 0.55,
    fontSize: 10, color: C.navy, bold: true, charSpacing: 1,
    align: "center", valign: "middle", margin: 0
  });

  const bloques = [
    { label: "Motivación IN FACTUM", color: C.navy, items: ["Hechos probados: 6 indicios concordantes", "Valoración conjunta y razonada (art. 139.5 Const.)", "Hechos no probados: pago real, entrega del bien"] },
    { label: "Motivación IN JURE", color: "059669", items: ["Art. 190 CC: simulación absoluta", "Art. 193 CC: legitimidad del tercero perjudicado", "Arts. 275-277 CPC: admisibilidad de indicios"] },
    { label: "Causales desestimadas", color: C.red, items: ["Art. 1351: autonomía de voluntad no ampara mala fe", "Art. 2014: buena fe registral — Roca Rojas no era de buena fe", "Arts. 275-276: indicios son prueba válida y legal"] },
  ];

  bloques.forEach((b, i) => {
    s.addShape(pres.shapes.RECTANGLE, {
      x: 6.9, y: 1.98 + i * 1.62, w: 5.6, h: 0.3,
      fill: { color: b.color }
    });
    s.addText(b.label, {
      x: 6.9, y: 1.98 + i * 1.62, w: 5.6, h: 0.3,
      fontSize: 9, color: C.white, bold: true, align: "center", valign: "middle", margin: 0
    });
    b.items.forEach((item, j) => {
      s.addText("▸ " + item, {
        x: 7.0, y: 2.35 + i * 1.62 + j * 0.36, w: 5.5, h: 0.33,
        fontSize: 9.5, color: C.slate, margin: 0
      });
    });
  });

  s.addNotes("ANÁLISIS — La sentencia tiene una estructura de motivación sólida: primero la motivación fáctica (hechos probados mediante indicios) y luego la motivación jurídica (subsunción en el Art. 190 CC). La Corte Suprema validó ambas dimensiones.");
}

