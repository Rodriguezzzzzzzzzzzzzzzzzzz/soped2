  });

  s.addNotes("CRÍTICA — La sentencia es jurídicamente correcta en su resultado pero adolece de escasa profundidad argumentativa. Un punto especialmente debatible es la presunción de mala fe del comprador sin prueba directa de su participación en el acuerdo simulatorio.");
}

// ─── SLIDE 13: CONCLUSIONES ──────────────────────────────────────────────────
{
  const s = pres.addSlide();
  s.background = { color: C.navy };
  sectionLabel(s, "CONCLUSIONES JURÍDICAS");

  s.addText("Conclusiones", {
    x: 0.5, y: 0.55, w: 12.3, h: 0.55,
    fontSize: 32, color: C.white, bold: true, fontFace: "Cambria",
    align: "left", margin: 0
  });

  const conclusiones = [
    { n: "01", t: "La simulación absoluta requiere acuerdo simulatorio", d: "No basta la voluntad unilateral. Se necesita el pactum simulationis entre las partes del acto aparente, el cual puede probarse mediante indicios concordantes." },
    { n: "02", t: "La prueba indiciaria es constitucionalmente válida", d: "Los Arts. 275-277 CPC y el Art. 139.5 de la Constitución avalan una sentencia basada en indicios, siempre que sean plurales, concordantes y concluyentes." },
    { n: "03", t: "La buena fe registral tiene límites en la mala fe subjetiva", d: "El Art. 2014 CC no protege al adquirente que conocía el vicio del título o las pretensiones de terceros antes de celebrar el acto." },
    { n: "04", t: "La nulidad del acto simulado es absoluta e imprescriptible", d: "Por aplicación del Art. 219 inc. 5 CC, la nulidad por simulación absoluta no puede ser convalidada y la acción no prescribe (Art. 2001 inc. 1 CC)." },
    { n: "05", t: "El tercero perjudicado tiene legitimidad activa plena", d: "Koch Müller, como titular de derechos sobre el bien derivados de la sociedad de gananciales no liquidada, tenía legitimidad activa para demandar (Art. 193 CC)." },
    { n: "06", t: "La ratio decidendi: protección material sobre forma registral", d: "La Corte Suprema privilegia la tutela del derecho sustantivo del tercero perjudicado sobre la apariencia registral creada fraudulentamente." },
  ];

  conclusiones.forEach((c, i) => {
    const col = i % 2;
    const row = Math.floor(i / 2);
    const xx = 0.5 + col * 6.35;
    const yy = 1.35 + row * 1.85;

    s.addShape(pres.shapes.RECTANGLE, {
      x: xx, y: yy, w: 6.1, h: 1.7,
      fill: { color: "0E2238" },
      line: { color: i < 2 ? C.gold : "2A4060", width: i < 2 ? 1 : 0.5 }
    });
    s.addShape(pres.shapes.RECTANGLE, {
      x: xx, y: yy, w: 0.07, h: 1.7,
      fill: { color: C.gold }
    });
    s.addText(c.n, {
      x: xx + 0.2, y: yy + 0.12, w: 0.55, h: 0.4,
      fontSize: 18, color: C.gold, bold: true, fontFace: "Cambria", margin: 0
    });
    s.addText(c.t, {
      x: xx + 0.85, y: yy + 0.12, w: 5.1, h: 0.45,
      fontSize: 11, color: C.white, bold: true, margin: 0
    });
    s.addText(c.d, {
      x: xx + 0.2, y: yy + 0.65, w: 5.7, h: 0.9,
      fontSize: 9.5, color: C.lgray, margin: 0
    });
  });

  s.addNotes("CONCLUSIONES — Estas seis conclusiones sintetizan el aporte del caso al Derecho Civil peruano. Destacar especialmente la conclusión 03 (límites de la buena fe) y la 06 (ratio decidendi) como los aportes jurisprudenciales más relevantes.");
}

